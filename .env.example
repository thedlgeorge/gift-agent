# Copy this file to .env and fill in your values
# Never commit .env to git — it's in .gitignore

# Required: Anthropic API key for the AI optimizer
ANTHROPIC_API_KEY=sk-ant-...

# Optional but recommended: Keepa API key for reliable price data
# Without this, the agent falls back to CamelCamelCamel scraping
# Sign up at https://keepa.com/#!api (~$20/month)
KEEPA_API_KEY=

# Optional: SendGrid for email alerts
SENDGRID_API_KEY=SG....
ALERT_FROM_EMAIL=you@example.com
ALERT_TO_EMAIL=you@example.com
